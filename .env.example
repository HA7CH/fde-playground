# ---- LLM (OpenAI 兼容；默认 DeepSeek) ----
# 不配也能跑：无 key 时 /api/chat 用内置 mock 人设回复（开箱即玩）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Supabase（对话采集 SessionDossier）----
# 不配也能跑：无配置时落库降级为服务端日志（no-op），不阻断对话
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI native mode（灰度开关，issue #16）----
# =1 时线索兜底判定交给 LLM 裁判（lib/judge.ts，温度0/json/逐字 evidence 三闸校验）；
# 关键词规则退居降级路径。不配 / 裁判失败 / 无 key 时行为与经典模式完全一致。
AI_NATIVE_MODE=
